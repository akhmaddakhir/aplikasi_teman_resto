rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function mappedUserId() {
      return signedIn() && exists(/databases/$(database)/documents/uid_mapping/$(request.auth.uid))
        ? get(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)).data.userId
        : null;
    }

    function currentUserDocId() {
      return mappedUserId() != null ? mappedUserId() : request.auth.uid;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.role == 'admin' ||
          (
            exists(/databases/$(database)/documents/users/$(currentUserDocId()))
            && get(/databases/$(database)/documents/users/$(currentUserDocId())).data.role == 'admin'
          )
        );
    }

    function isApprovedPartner() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(currentUserDocId()))
        && get(/databases/$(database)/documents/users/$(currentUserDocId())).data.role == 'partner';
    }

    function isRestaurantOwner(restaurantId) {
      return signedIn()
        && restaurantId is string
        && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
        && (
          get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid ||
          get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == mappedUserId()
        );
    }
    
    // Users 
    match /users/{userId} {
      // User doc memakai custom ID, contoh: USR-0000001.
      // Akses dicek lewat field firebaseUid.
      allow create: if request.auth != null
        && request.resource.data.firebaseUid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.firebaseUid == request.auth.uid;
      // Admin bisa read semua users
      allow read: if request.auth.token.role == 'admin';

      match /wishlist/{wishlistId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid;
        allow read, write: if request.auth.token.role == 'admin';
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null
          && (
            get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid ||
            get(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)).data.userId == userId
          );
        allow create: if request.auth != null
          && (
            get(/databases/$(database)/documents/users/$(userId)).data.firebaseUid == request.auth.uid ||
            get(/databases/$(database)/documents/uid_mapping/$(request.auth.uid)).data.userId == userId ||
            (
              request.resource.data.type == 'booking' &&
              request.resource.data.bookingId is string &&
              get(/databases/$(database)/documents/reservations/$(request.resource.data.bookingId)).data.customUserId == userId &&
              request.auth.uid == get(/databases/$(database)/documents/restaurants/$(get(/databases/$(database)/documents/reservations/$(request.resource.data.bookingId)).data.restaurantId)).data.ownerId
            )
          );
        allow read, write: if request.auth.token.role == 'admin';
      }
    }

    // Uid Mapping
    match /uid_mapping/{firebaseUid} {
      allow read, write: if request.auth != null
        && request.auth.uid == firebaseUid;
      allow read, write: if request.auth.token.role == 'admin';
    }

    // Counters
    match /counters/{counterId} {
      allow read, write: if request.auth != null
        && counterId in [
          'user_counter',
          'restaurant_counter',
          'area_counter',
          'menu_counter',
          'review_counter',
          'wishlist_counter',
          'notification_counter',
          'reservation_counter',
        ];
      allow read, write: if request.auth.token.role == 'admin';
    }

    // ========== RESTAURANTS (Partner) ==========
    match /partners/{partnerId} {
      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.uid == request.auth.uid ||
          request.resource.data.ownerId == request.auth.uid ||
          request.resource.data.userId == currentUserDocId() ||
          request.resource.data.uid == currentUserDocId() ||
          request.resource.data.ownerId == currentUserDocId()
        )
        && request.resource.data.status in ['pending', 'approved', 'active'];
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          resource.data.ownerId == request.auth.uid ||
          resource.data.userId == currentUserDocId() ||
          resource.data.uid == currentUserDocId() ||
          resource.data.ownerId == currentUserDocId()
        );
      allow update: if signedIn()
        && (
          resource.data.userId == request.auth.uid ||
          resource.data.uid == request.auth.uid ||
          resource.data.ownerId == request.auth.uid ||
          resource.data.userId == currentUserDocId() ||
          resource.data.uid == currentUserDocId() ||
          resource.data.ownerId == currentUserDocId()
        )
        && request.resource.data.status in ['pending', 'approved', 'active'];
      allow read, write: if isAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (
          signedIn()
          && (
            request.resource.data.ownerId == request.auth.uid ||
            request.resource.data.ownerId == currentUserDocId()
          )
        );
      allow update, delete: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.ownerId == request.auth.uid ||
            resource.data.ownerId == currentUserDocId()
          )
        );

      // Sub-collection: menus
      match /menus/{menuId} {
        allow read, write: if request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId;
        allow read: if request.auth != null;
      }
    }

    // ========== RESTAURANT AREAS ==========
    match /restaurant_areas/{areaId} {
      allow read: if signedIn()
        && (
          resource.data.isActive == true ||
          isRestaurantOwner(resource.data.restaurantId) ||
          isAdmin()
        );
      allow create: if isRestaurantOwner(request.resource.data.restaurantId);
      allow update: if isRestaurantOwner(resource.data.restaurantId)
        && request.resource.data.restaurantId == resource.data.restaurantId;
      allow delete: if isRestaurantOwner(resource.data.restaurantId);
      allow read, write: if isAdmin();
    }

    // ========== RESERVATIONS ==========
    match /reservations/{reservationId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId
        );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId
        );
      allow read, write: if request.auth.token.role == 'admin';
    }

    // ========== RESERVATION LOCKS ==========
    match /reservation_locks/{lockId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId
        );
      allow read, write: if request.auth.token.role == 'admin';
    }

    // ========== BOOKINGS ==========
    match /bookings/{bookingId} {
      // User bisa baca booking mereka
      allow read: if request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId;
      // User bisa buat booking
      allow create: if request.auth.uid == request.resource.data.userId;
      // User/Restaurant bisa update booking mereka
      allow update: if request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId;
      // Admin bisa do anything
      allow read, write: if request.auth.token.role == 'admin';
    }

    // ========== REVIEWS ==========
    match /reviews/{reviewId} {
      // Anyone authenticated bisa read
      allow read: if request.auth != null;
      // User bisa create/update review mereka
      allow create, update: if request.auth.uid == request.resource.data.userId;
      // Admin bisa delete
      allow delete: if request.auth.token.role == 'admin';
    }

    // ========== NOTIFICATIONS ==========
    match /notifications/{notificationId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.userId == resource.data.userId;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
